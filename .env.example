# Copy this file to .env and adjust values for your environment.
# Never commit .env to version control.

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://metricstore:metricstore@localhost:5432/metricstore

# ── Application ───────────────────────────────────────────────────────────────
APP_NAME=MetricStore
DEBUG=false
API_PREFIX=/api/v1

# ── Authentication (optional) ────────────────────────────────────────────────
# Local development: keep AUTH_ENABLED=false for no auth.
# Production/self-hosted: set AUTH_ENABLED=true and provide one or more API keys.
AUTH_ENABLED=false
# Comma-separated API keys. Example:
# API_KEYS=prod-key-1,prod-key-2
API_KEYS=
